rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == "digitalsoutien@gmail.com";
    }
    match /kits/{kitId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == "digitalsoutien@gmail.com";
    }
    match /settings/{settingsId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == "digitalsoutien@gmail.com";
    }
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == "digitalsoutien@gmail.com";
    }
    match /clients/{clientId} {
      allow read: if request.auth != null && (request.auth.uid == clientId || request.auth.token.email == "digitalsoutien@gmail.com");
      allow create: if request.auth != null && request.auth.uid == clientId;
      allow update: if request.auth != null && (request.auth.uid == clientId || request.auth.token.email == "digitalsoutien@gmail.com");
      allow delete: if request.auth != null && request.auth.token.email == "digitalsoutien@gmail.com";
    }
    match /paiements/{paymentId} {
      allow read: if request.auth != null && (resource.data.clientId == request.auth.uid || request.auth.token.email == "digitalsoutien@gmail.com");
      allow create: if request.auth != null && (request.resource.data.clientId == request.auth.uid || request.auth.token.email == "digitalsoutien@gmail.com");
      allow update, delete: if request.auth != null && request.auth.token.email == "digitalsoutien@gmail.com";
    }
  }
}
